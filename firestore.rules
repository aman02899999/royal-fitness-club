rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the authenticated user is an admin
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // codes/{code} - membership codes generated by admin
    // Anyone (even unauthenticated) can read a code to validate it before signup.
    // Only admins can create/delete. An authenticated user can mark their own code used.
    match /codes/{code} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if request.auth != null
        && request.resource.data.used == true
        && request.resource.data.usedBy == request.auth.uid
        && resource.data.used == false;
    }

    // users/{uid} - user profiles
    // Self-registration via membership code: a new user may create their own doc
    // if the membership code in the request is valid and unused.
    // Updates are restricted — plan, role, and membershipExpiry cannot be changed by the user,
    // except a paid plan upgrade (lastPaymentId must be present and non-empty).
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.get('role', 'member') == 'member'
        && request.resource.data.get('gymMember', false) == true
        && request.resource.data.get('memberCode', '') != '';
      allow update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.get('role', 'member') == resource.data.get('role', 'member')
        && request.resource.data.get('membershipExpiry', null) == resource.data.get('membershipExpiry', null)
        && (
          // No plan change — general profile update
          request.resource.data.get('plan', 'free') == resource.data.get('plan', 'free')
          // Downgrade to free allowed
          || request.resource.data.get('plan', 'free') == 'free'
          // Paid upgrade: plan is a known paid tier AND lastPaymentId is being set
          || (request.resource.data.plan in ['royal_pro', 'royal_elite']
              && request.resource.data.get('lastPaymentId', '') != ''
              && request.resource.data.lastPaymentId != resource.data.get('lastPaymentId', ''))
        );
      allow read, write: if isAdmin();

      // renewals subcollection — written by admin when renewing membership
      match /renewals/{renewalId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if isAdmin();
      }
    }

    // subscriptions/{subId} - subscription records
    // Owners may read their own and cancel (status -> 'cancelled' only,
    // without touching uid/plan/amount). All other writes are admin/backend.
    match /subscriptions/{subId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.status == 'cancelled'
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.plan == resource.data.plan
        && request.resource.data.amount == resource.data.amount;
      allow write: if isAdmin();
    }

    // measurements/{uid}/logs/{logId} - body measurements
    match /measurements/{uid}/logs/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // progress_logs/{uid}/logs/{logId} - calculator results
    match /progress_logs/{uid}/logs/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // activity/{uid} - streak/workout tracking
    match /activity/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // pending_users/{id} - temporary login data
    match /pending_users/{id} {
      allow write: if true;
      allow read: if request.auth != null && request.auth.uid == id;
    }

    // analytics/{uid}/events/{eventId} - per-user event stream
    match /analytics/{uid}/events/{eventId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // global_analytics/{eventName} - aggregated event counters (admin read, auth write)
    match /global_analytics/{eventName} {
      allow read: if isAdmin();
      allow write: if request.auth != null;
    }

    // pending_payments/{orderId} - Razorpay payment records
    match /pending_payments/{orderId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin();
    }

    // payment_orders/{orderId} - Cloud Function server-side order records
    match /payment_orders/{orderId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if isAdmin();
    }

    // users/{uid}/course_purchases/{courseId} - course enrollment records
    match /users/{uid}/course_purchases/{courseId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if (request.auth != null && request.auth.uid == uid) || isAdmin();
    }

    // physio_logs/{uid}/logs/{logId} - physio assessment history
    match /physio_logs/{uid}/logs/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // physio_summary/{uid} - latest physio scores
    match /physio_summary/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // leaderboard/{uid} - community leaderboard (any member reads, owner writes)
    match /leaderboard/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
      allow delete: if isAdmin();
    }

    // pdf_purchases/{uid}/items/{itemId} - one-time digital product purchases
    // Owner can read their own purchases; only Cloud Functions / admin can write.
    match /pdf_purchases/{uid}/items/{itemId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    // pdf_catalog/{itemId} - publicly readable PDF product listings
    match /pdf_catalog/{itemId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // announcements/{aid} - gym-wide messages posted by admin, read by all members
    match /announcements/{aid} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ai_rate_limits/{uid_date} - per-user daily AI usage counter; Cloud Function writes via admin SDK
    match /ai_rate_limits/{docId} {
      allow read: if request.auth != null && docId.matches(request.auth.uid + '_.*');
      allow write: if false;
    }

    // admin_config/{docId} - nav control, challenges, plans config set by admin
    match /admin_config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // notify_me/{id} - "notify me" email captures from locked feature overlay
    match /notify_me/{id} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // admin_inbox/{id} - new member notifications for admin
    match /admin_inbox/{id} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // elite_applications/{id} - Royal Elite coaching applications
    match /elite_applications/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // newsletter_subscribers/{id} - newsletter signups
    match /newsletter_subscribers/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ref_codes/{code} - referral code → owner UID mapping
    // Any auth user can read (needed to look up referrer UID when applying a code).
    // Only the owner can create their own entry. Immutable after creation.
    match /ref_codes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // referrals/{newUserUid} - referral event per new member
    // Owner can read their own record; create allowed on signup.
    // Updates (marking bonuses paid) require the referrer or admin —
    // enforced by only allowing the referrerUid field to be unchanged.
    match /referrals/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid
            || request.auth.uid == resource.data.referrerUid
            || isAdmin());
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.get('purchaseBonusPaid', false) == false
        && request.resource.data.get('signupBonusPaid', false) == false;
      // Any auth user can update to mark bonus paid; referrer UID + code must not change
      allow update: if request.auth != null
        && request.resource.data.referrerUid == resource.data.referrerUid
        && request.resource.data.refCode == resource.data.refCode;
      allow delete: if isAdmin();
    }

    // wallets/{uid} - Tiger wallet balances (cross-device sync)
    // Owner reads their own wallet.
    // Owner can write their own wallet (for debits / login bonus / local sync).
    // Other authenticated users may only CREDIT this wallet (referral bonuses):
    //   balance must not decrease and at most one new transaction entry is added.
    match /wallets/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null
        && request.auth.uid != uid
        && request.resource.data.balance >= resource.data.balance
        && request.resource.data.transactions.size() <= resource.data.transactions.size() + 1;
      allow read, write: if isAdmin();
    }

    // redeem_requests/{id} - UPI payout requests
    // Owners can create their own requests; admin manages fulfillment.
    match /redeem_requests/{id} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.amount >= 500;
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }
  }
}
